<Window x:Class="VisaManager.DetailClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client Details" Height="800" Width="700"
        Background="#f5f7fa"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#007acc"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <TextBlock Text="🧾 Client Details" FontSize="22" FontWeight="Bold" Margin="0 0 0 20" DockPanel.Dock="Top"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <!-- Add rows for each item -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Left labels -->
            <TextBlock Text="Name:" Grid.Row="0" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Passport No:" Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Email:" Grid.Row="2" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Visa Type:" Grid.Row="3" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Expire Date:" Grid.Row="4" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Country:" Grid.Row="5" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Company:" Grid.Row="6" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Passport File:" Grid.Row="7" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Photo:" Grid.Row="8" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Rekening:" Grid.Row="9" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="NPWP:" Grid.Row="10" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="KTP:" Grid.Row="11" Grid.Column="0" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Permohonan:" Grid.Row="12" Grid.Column="0" FontWeight="Bold" Margin="5"/>

            <!-- Right info -->
            <TextBlock x:Name="NameText" Grid.Row="0" Grid.Column="1" Margin="5"/>
            <TextBlock x:Name="PassportNumberText" Grid.Row="1" Grid.Column="1" Margin="5"/>
            <TextBlock x:Name="EmailText" Grid.Row="2" Grid.Column="1" Margin="5"/>
            <TextBlock x:Name="VisaTypeText" Grid.Row="3" Grid.Column="1" Margin="5"/>
            <TextBlock x:Name="ExpireDateText" Grid.Row="4" Grid.Column="1" Margin="5"/>
            <TextBlock x:Name="CountryText" Grid.Row="5" Grid.Column="1" Margin="5"/>
            <TextBlock x:Name="CompanyText" Grid.Row="6" Grid.Column="1" Margin="5"/>
            <TextBlock Grid.Row="7" Grid.Column="1" Margin="5">
                <Hyperlink x:Name="PassportLink" Click="OpenFile_Click">View File</Hyperlink>
            </TextBlock>
            <TextBlock Grid.Row="8" Grid.Column="1" Margin="5">
                <Hyperlink x:Name="PasPhotoLink" Click="OpenFile_Click">View Photo</Hyperlink>
            </TextBlock>
            <TextBlock Grid.Row="9" Grid.Column="1" Margin="5">
                <Hyperlink x:Name="RekeningLink" Click="OpenFile_Click">Open Rekening</Hyperlink>
            </TextBlock>
            <TextBlock Grid.Row="10" Grid.Column="1" Margin="5">
                <Hyperlink x:Name="NPWPLink" Click="OpenFile_Click">Open NPWP</Hyperlink>
            </TextBlock>
            <TextBlock Grid.Row="11" Grid.Column="1" Margin="5">
                <Hyperlink x:Name="KTPLink" Click="OpenFile_Click">Open KTP</Hyperlink>
            </TextBlock>
            <TextBlock Grid.Row="12" Grid.Column="1" Margin="5">
                <Hyperlink x:Name="PermohonanLink" Click="OpenFile_Click">Open Permohonan</Hyperlink>
            </TextBlock>
        </Grid>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0">
            <Button Content="Edit" Click="Edit_Click"/>
            <Button Content="Delete" Click="Delete_Click" Background="#e53935"/>
        </StackPanel>
    </DockPanel>
</Window>
